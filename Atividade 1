#include <stdio.h>
int main() {
    int matriz[3][3];
    int i, j;
    // Leitura da matriz
    printf("Digite os elementos da matriz 3x3:\n");
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            printf("Elemento [%d][%d]: ", i, j);
            scanf("%d", &matriz[i][j]);
        }
    }
    // Multiplicando por 5 e exibindo resultado
    printf("\nMatriz resultante (multiplicada por 5):\n");
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            printf("%d ", matriz[i][j] * 5);
        }
        printf("\n");
    }

    return 0;
}
