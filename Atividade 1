#include <stdio.h>

int main() {
    char palavra1[50];
    char palavra2[50];
    char palavra3[50];

    printf("Digite a primeira palavra: ");
    scanf("%s", palavra1);

    printf("Digite a segunda palavra: ");
    scanf("%s", palavra2);

    printf("Digite a terceira palavra: ");
    scanf("%s", palavra3);

    printf("\nNa ordem inversa:\n");
    printf("3ª: %s\n", palavra3);
    printf("2ª: %s\n", palavra2);
    printf("1ª: %s\n", palavra1);

    return 0;
}
//Versão Alternativa do exercicio 1
#include <stdio.h>

int main() {
    char palavras[3][50];

    printf("Digite tres palavras (uma por linha):\n");

    for(int i = 0; i < 3; i++) {
        printf("Palavra %d: ", i+1);
        scanf("%s", palavras[i]);
    }

    printf("\nOrdem inversa:\n");
    for(int i = 2; i >= 0; i--) {
        printf("%s\n", palavras[i]);
    }

    return 0;
}

//EXERCICIO 2
#include <stdio.h>

int main() {
    int vetor[5];
    
    printf("Digite 5 numeros inteiros:\n");
    
    for(int i = 0; i < 5; i++) {
        printf("Numero %d: ", i+1);
        scanf("%d", &vetor[i]);
    }
    
    printf("\nVetor na ordem inversa:\n");
    
    for(int i = 4; i >= 0; i--) {
        printf("\n%d ", vetor[i]);
    }
    
    printf("\n");
    
    return 0;
}

